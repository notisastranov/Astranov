# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: Required for PostgreSQL/MySQL database connection.
# Example: mysql://user:password@localhost:3306/astranov
DATABASE_URL=

# GOOGLE_MAPS_API_KEY: Required for native Google Maps JS API and Places.
GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAPS_API_KEY=

# GITHUB_TOKEN: GitHub Personal Access Token for repository operations.
GITHUB_TOKEN=
# GITHUB_REPO: The name of the GitHub repository (e.g., 'astranov-app').
GITHUB_REPO=
# GITHUB_OWNER: The owner of the GitHub repository (e.g., 'astranov-org').
GITHUB_OWNER=

# YOUTUBE_API_KEY: Required for YouTube Data API v3 calls.
YOUTUBE_API_KEY=

# FIREBASE CONFIGURATION: Required for Firestore and Auth.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_PROJECT_ID=
FIREBASE_PROJECT_ID=
